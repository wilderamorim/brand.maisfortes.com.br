---
import BrandbookLayout from '@/layouts/BrandbookLayout.astro';
import Section from '@/components/layout/Section.astro';
---

<BrandbookLayout
  pageNumber="2.0"
  pageTitle="Cards"
  pageSubtitle="Cards de progresso, apoiador, check-in e meta."
  sectionsCount={4}
>

  <!-- 01 Check-in Card -->
  <Section number="01" title="Check-in Card" subtitle="Componente core — registro diário">
    <div class="max-w-md mx-auto">
      <div class="surface-elevated p-6 rounded-[20px] space-y-5">
        <div class="flex items-center justify-between">
          <span class="font-mono text-xs t-muted">Hoje, 9 de abril</span>
          <span class="font-mono text-[10px] text-brand-forest">Dia 8</span>
        </div>
        <h3 class="font-display font-bold text-lg t-heading">Como foi seu dia?</h3>
        <div class="flex justify-between">
          {[
            { emoji: '😔', label: 'Difícil', color: 'bg-brand-coral' },
            { emoji: '😕', label: 'Complicado', color: 'bg-brand-coral-light' },
            { emoji: '😐', label: 'Normal', color: 'bg-brand-dark-border' },
            { emoji: '🙂', label: 'Bom', color: 'bg-brand-forest-200' },
            { emoji: '😊', label: 'Ótimo', color: 'bg-brand-forest' },
          ].map((score, i) => (
            <button class:list={[
              'flex flex-col items-center gap-1 p-2 rounded-xl transition-all',
              i === 3 ? 'bg-brand-forest/15 ring-2 ring-brand-forest scale-105' : 'hover:t-surface',
            ]}>
              <span class="text-2xl">{score.emoji}</span>
              <span class="text-[10px] t-muted">{score.label}</span>
            </button>
          ))}
        </div>
        <textarea
          class="w-full t-surface border t-border/50 rounded-[10px] p-3 text-sm t-heading placeholder:t-muted/50 resize-none"
          rows="2"
          placeholder="Nota (opcional)..."
        ></textarea>
        <button class="w-full py-2.5 bg-brand-forest text-white rounded-[12px] font-body font-semibold text-sm hover:bg-brand-forest-light transition-colors shadow-glow">
          Registrar check-in
        </button>
      </div>
    </div>
  </Section>

  <!-- 02 Streak Card -->
  <Section number="02" title="Streak Card" subtitle="Sequência de dias">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <!-- Active streak -->
      <div class="surface-elevated p-6 rounded-[20px] text-center shadow-glow">
        <span class="font-mono text-[10px] text-brand-forest uppercase tracking-widest">Streak ativo</span>
        <div class="flex items-center justify-center gap-2 mt-2">
          <span class="font-mono font-bold text-5xl t-heading">30</span>
          <span class="text-2xl">🔥</span>
        </div>
        <p class="font-body text-sm t-muted mt-1">dias seguidos</p>
        <span class="inline-block mt-3 px-3 py-1 rounded-full bg-brand-amber/15 text-brand-amber text-xs font-mono">1 mês!</span>
      </div>
      <!-- Early streak -->
      <div class="surface-card p-6 rounded-[20px] text-center">
        <span class="font-mono text-[10px] t-muted uppercase tracking-widest">Começando</span>
        <div class="flex items-center justify-center gap-2 mt-2">
          <span class="font-mono font-bold text-5xl t-heading">3</span>
        </div>
        <p class="font-body text-sm t-muted mt-1">dias seguidos</p>
      </div>
      <!-- Broken streak -->
      <div class="surface-card p-6 rounded-[20px] text-center t-border/30">
        <span class="font-mono text-[10px] t-muted uppercase tracking-widest">Pausado</span>
        <div class="flex items-center justify-center gap-2 mt-2">
          <span class="font-mono font-bold text-5xl t-muted">0</span>
        </div>
        <p class="font-body text-sm t-muted mt-1">Bora voltar?</p>
      </div>
    </div>
  </Section>

  <!-- 03 Goal Card -->
  <Section number="03" title="Goal Card" subtitle="Meta do protagonista">
    <div class="max-w-md">
      <div class="surface-card p-5 rounded-[16px] space-y-3">
        <div class="flex items-center justify-between">
          <span class="px-2 py-0.5 rounded-full bg-brand-forest/15 text-brand-forest text-xs font-mono">Ativa</span>
          <span class="font-mono text-[10px] t-muted">Desde 01/04</span>
        </div>
        <h4 class="font-display font-bold text-lg t-heading">Parar de beber</h4>
        <p class="text-sm t-muted">Manter sobriedade completa por 90 dias.</p>
        <div class="flex items-center gap-3 pt-2 border-t t-border/30">
          <div class="flex items-center gap-1.5">
            <span class="text-brand-forest">🔥</span>
            <span class="font-mono text-xs t-heading">8 dias</span>
          </div>
          <div class="flex items-center gap-1.5">
            <span>👥</span>
            <span class="font-mono text-xs t-muted">3 apoiadores</span>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- 04 Supporter Card -->
  <Section number="04" title="Supporter Card" subtitle="Card do apoiador">
    <div class="max-w-md">
      <div class="surface-card p-5 rounded-[16px]">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-brand-coral/20 flex items-center justify-center">
            <span class="font-display font-bold text-brand-coral">M</span>
          </div>
          <div class="flex-1">
            <h4 class="font-body font-semibold text-sm t-heading">Maria</h4>
            <span class="font-mono text-[10px] t-muted">Apoiadora desde 01/04</span>
          </div>
          <span class="px-2 py-0.5 rounded-full bg-brand-forest/15 text-brand-forest text-[10px] font-mono">Ativa</span>
        </div>
      </div>
    </div>
  </Section>

</BrandbookLayout>
