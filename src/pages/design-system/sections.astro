---
import BrandbookLayout from '@/layouts/BrandbookLayout.astro';
import Section from '@/components/layout/Section.astro';
---

<BrandbookLayout
  pageNumber="7.0"
  pageTitle="Sections"
  pageSubtitle="Blocos de marketing e landing page reutilizaveis."
  sectionsCount={4}
>

  <Section number="01" title="Hero Section" subtitle="Bloco principal da landing page">
    <div class="surface-elevated p-8 md:p-12 rounded-[20px] text-center space-y-6 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-brand-forest/5 to-transparent pointer-events-none"></div>
      <div class="relative z-10">
        <span class="font-mono text-xs text-brand-forest uppercase tracking-widest">Plataforma gratuita</span>
        <h2 class="font-display font-bold text-3xl md:text-5xl text-white mt-3 leading-tight">
          Juntos, somos<br /><span class="text-gradient-forest">+Fortes</span>
        </h2>
        <p class="text-brand-dark-muted max-w-lg mx-auto mt-4">
          Acompanhe sua jornada de mudanca com quem te apoia. Check-in diario, streak e rede de apoio — tudo em um so lugar.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-3 mt-6">
          <button class="px-8 py-3 bg-brand-forest text-white rounded-[12px] font-body font-semibold shadow-glow hover:bg-brand-forest-light transition-colors">
            Comece sua jornada
          </button>
          <button class="px-8 py-3 bg-transparent text-brand-dark-muted rounded-[12px] font-body font-semibold hover:text-white transition-colors">
            Saiba mais
          </button>
        </div>
      </div>
    </div>
  </Section>

  <Section number="02" title="Features Grid" subtitle="Bloco de funcionalidades">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {[
        { icon: '📊', title: 'Check-in diario', desc: 'Registre como foi seu dia em segundos. Score de 1 a 5 + nota opcional.' },
        { icon: '🔥', title: 'Streak', desc: 'Acompanhe sua sequencia de dias. Cada dia conta.' },
        { icon: '👥', title: 'Rede de apoio', desc: 'Convide quem te apoia. Eles acompanham sem invadir.' },
        { icon: '🔔', title: 'Alertas', desc: 'Sua rede recebe alerta se voce parar. Ninguem fica sozinho.' },
        { icon: '🔒', title: 'Privacidade total', desc: 'Voce controla tudo. Nada e compartilhado sem sua permissao.' },
        { icon: '💬', title: 'Mensagens', desc: 'Receba incentivo de quem te apoia nos momentos que mais precisa.' },
      ].map((f) => (
        <div class="surface-card p-5 space-y-2">
          <span class="text-2xl">{f.icon}</span>
          <h4 class="font-display font-bold text-white">{f.title}</h4>
          <p class="text-sm text-brand-dark-muted">{f.desc}</p>
        </div>
      ))}
    </div>
  </Section>

  <Section number="03" title="Social Proof" subtitle="Bloco de prova social">
    <div class="surface-card p-8 text-center rounded-[20px]">
      <span class="font-mono text-xs text-brand-dark-muted uppercase tracking-widest">Depoimento</span>
      <blockquote class="font-display text-xl md:text-2xl text-white mt-4 max-w-2xl mx-auto leading-relaxed">
        "Eu tentei parar de beber sozinho varias vezes. Quando minha irma comecou a acompanhar pelo app, tudo mudou. Saber que alguem olha por mim sem me julgar fez toda a diferenca."
      </blockquote>
      <div class="mt-4 text-sm text-brand-dark-muted">— Protagonista anonimo</div>
    </div>
  </Section>

  <Section number="04" title="CTA Final" subtitle="Bloco de chamada a acao">
    <div class="surface-elevated p-8 md:p-12 rounded-[20px] text-center relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-r from-brand-forest/5 via-transparent to-brand-coral/5 pointer-events-none"></div>
      <div class="relative z-10">
        <h3 class="font-display font-bold text-2xl md:text-3xl text-white">
          Ninguem muda sozinho.
        </h3>
        <p class="text-brand-dark-muted mt-3 max-w-md mx-auto">
          Comece sua jornada e convide quem te apoia. E gratuito, sempre.
        </p>
        <button class="mt-6 px-8 py-3 bg-brand-forest text-white rounded-[12px] font-body font-semibold shadow-glow hover:bg-brand-forest-light transition-colors">
          Comece agora — e gratis
        </button>
      </div>
    </div>
  </Section>

</BrandbookLayout>
