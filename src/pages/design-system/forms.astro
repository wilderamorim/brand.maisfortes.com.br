---
import BrandbookLayout from '@/layouts/BrandbookLayout.astro';
import Section from '@/components/layout/Section.astro';
---

<BrandbookLayout
  pageNumber="3.0"
  pageTitle="Forms"
  pageSubtitle="Inputs, seletores, textarea e formulários compostos."
  sectionsCount={4}
>

  <Section number="01" title="Text Inputs" subtitle="Campos de texto básicos">
    <div class="max-w-md space-y-4">
      <div class="space-y-1.5">
        <label class="text-sm font-body font-medium t-heading">Nome</label>
        <input type="text" placeholder="Seu nome" class="w-full t-surface border t-border/50 rounded-[10px] px-4 py-2.5 text-sm t-heading placeholder:t-muted/50 focus:outline-none focus:ring-2 focus:ring-brand-forest/50 focus:border-brand-forest transition-all" />
      </div>
      <div class="space-y-1.5">
        <label class="text-sm font-body font-medium t-heading">Email</label>
        <input type="email" placeholder="seu@email.com" class="w-full t-surface border t-border/50 rounded-[10px] px-4 py-2.5 text-sm t-heading placeholder:t-muted/50 focus:outline-none focus:ring-2 focus:ring-brand-forest/50 focus:border-brand-forest transition-all" />
      </div>
      <div class="space-y-1.5">
        <label class="text-sm font-body font-medium t-heading">Senha</label>
        <input type="password" placeholder="********" class="w-full t-surface border t-border/50 rounded-[10px] px-4 py-2.5 text-sm t-heading placeholder:t-muted/50 focus:outline-none focus:ring-2 focus:ring-brand-forest/50 focus:border-brand-forest transition-all" />
      </div>
    </div>
  </Section>

  <Section number="02" title="Score Selector" subtitle="Componente core — seleção de humor">
    <div class="max-w-md">
      <div class="surface-card p-6">
        <p class="font-display font-bold t-heading mb-4">Como foi seu dia?</p>
        <div class="flex justify-between">
          {[
            { emoji: '😔', label: 'Difícil', bg: 'bg-brand-coral/15 border-brand-coral/30' },
            { emoji: '😕', label: 'Complicado', bg: 'bg-brand-coral/10 border-brand-coral/20' },
            { emoji: '😐', label: 'Normal', bg: 'bg-brand-dark-border/30 t-border/50' },
            { emoji: '🙂', label: 'Bom', bg: 'bg-brand-forest/10 border-brand-forest/20' },
            { emoji: '😊', label: 'Ótimo', bg: 'bg-brand-forest/20 border-brand-forest/40' },
          ].map((s) => (
            <button class={`flex flex-col items-center gap-1 p-3 rounded-xl border transition-all hover:scale-105 ${s.bg}`}>
              <span class="text-2xl">{s.emoji}</span>
              <span class="text-[10px] t-muted">{s.label}</span>
            </button>
          ))}
        </div>
      </div>
    </div>
  </Section>

  <Section number="03" title="Textarea" subtitle="Campo de nota opcional">
    <div class="max-w-md">
      <div class="space-y-1.5">
        <label class="text-sm font-body font-medium t-heading">Nota do dia</label>
        <textarea
          rows="3"
          placeholder="Como você está se sentindo? (opcional)"
          class="w-full t-surface border t-border/50 rounded-[10px] px-4 py-3 text-sm t-heading placeholder:t-muted/50 focus:outline-none focus:ring-2 focus:ring-brand-forest/50 focus:border-brand-forest transition-all resize-none"
        ></textarea>
        <span class="text-[10px] t-muted/60 font-mono">Máximo 500 caracteres</span>
      </div>
    </div>
  </Section>

  <Section number="04" title="Formulário Composto" subtitle="Criar meta — exemplo real">
    <div class="max-w-md">
      <div class="surface-elevated p-6 rounded-[20px] space-y-5">
        <h3 class="font-display font-bold text-lg t-heading">Criar nova meta</h3>
        <div class="space-y-1.5">
          <label class="text-sm font-body font-medium t-heading">Qual é sua meta?</label>
          <input type="text" value="Parar de beber" class="w-full t-surface border t-border/50 rounded-[10px] px-4 py-2.5 text-sm t-heading focus:outline-none focus:ring-2 focus:ring-brand-forest/50 transition-all" />
        </div>
        <div class="space-y-1.5">
          <label class="text-sm font-body font-medium t-heading">Descreva em poucas palavras</label>
          <textarea rows="2" class="w-full t-surface border t-border/50 rounded-[10px] px-4 py-3 text-sm t-heading placeholder:t-muted/50 focus:outline-none focus:ring-2 focus:ring-brand-forest/50 transition-all resize-none" placeholder="Por que essa meta é importante pra você?"></textarea>
        </div>
        <button class="w-full py-2.5 bg-brand-forest text-white rounded-[12px] font-body font-semibold text-sm hover:bg-brand-forest-light transition-colors shadow-glow">
          Começar jornada
        </button>
      </div>
    </div>
  </Section>

</BrandbookLayout>
