---
import BaseLayout from '@/layouts/BaseLayout.astro';
import StickyNav from '@/components/nav/StickyNav.astro';
import { brand } from '@/lib/brand';

const currentPath = Astro.url.pathname;
---

<BaseLayout title="404 — Pagina nao encontrada | +Fortes">
  <StickyNav currentPath={currentPath} />

  <main class="lg:ml-64 min-h-screen flex items-center justify-center relative">
    <!-- Background glow -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[300px] rounded-full bg-brand-coral/5 blur-3xl"></div>
    </div>

    <div class="text-center px-4 relative z-10">
      <!-- Big 404 -->
      <div class="flex items-center justify-center gap-2 mb-6">
        <span class="font-mono text-8xl md:text-9xl font-bold text-brand-dark-border/50">4</span>
        <div class="w-20 h-20 md:w-24 md:h-24 rounded-2xl bg-brand-forest/10 border border-brand-forest/20 flex items-center justify-center">
          <span class="font-display font-bold text-4xl md:text-5xl text-brand-forest">+</span>
        </div>
        <span class="font-mono text-8xl md:text-9xl font-bold text-brand-dark-border/50">4</span>
      </div>

      <!-- Message -->
      <h1 class="font-display font-bold text-2xl md:text-3xl text-white mb-3">
        Pagina nao encontrada
      </h1>
      <p class="text-brand-dark-muted max-w-md mx-auto mb-8">
        Essa pagina nao existe ou foi movida. Mas tudo bem — nem todo caminho e reto. O importante e voltar.
      </p>

      <!-- Actions -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="/"
          class="px-6 py-2.5 bg-brand-forest text-white rounded-[12px] font-body font-semibold text-sm hover:bg-brand-forest-light transition-colors shadow-glow"
        >
          Voltar ao inicio
        </a>
        <a
          href="/brandbook/"
          class="px-6 py-2.5 bg-transparent text-brand-dark-muted rounded-[12px] font-body font-semibold text-sm hover:text-white hover:bg-brand-dark-surface transition-colors"
        >
          Ver Guidelines
        </a>
      </div>

      <!-- Footer -->
      <div class="mt-16 font-mono text-[10px] text-brand-dark-muted/50 tracking-wider">
        {brand.name} <span class="text-brand-dark-border">//</span> Brand Identity System <span class="text-brand-dark-border">//</span> v{brand.version}
      </div>
    </div>
  </main>
</BaseLayout>
