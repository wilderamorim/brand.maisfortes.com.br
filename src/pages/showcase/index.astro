---
import BrandbookLayout from '@/layouts/BrandbookLayout.astro';
import Section from '@/components/layout/Section.astro';
---

<BrandbookLayout
  pageNumber="0.0"
  pageTitle="Editorial"
  pageSubtitle="Showcase editorial da marca +Fortes."
  sectionsCount={3}
>

  <!-- 01 Hero -->
  <Section number="01" title="Brand Summary" subtitle="Visão condensada">
    <div class="surface-elevated p-8 md:p-12 rounded-[20px] space-y-8">
      <!-- Logo + Name -->
      <div class="flex items-center gap-4">
        <div class="w-16 h-16 rounded-xl bg-brand-forest flex items-center justify-center shadow-glow-md">
          <span class="font-display font-bold text-4xl t-heading">+</span>
        </div>
        <div>
          <h2 class="font-display font-bold text-3xl t-heading">+Fortes</h2>
          <p class="font-mono text-xs t-muted">maisfortes.com.br</p>
        </div>
      </div>

      <!-- Tagline -->
      <p class="font-display font-bold text-2xl md:text-3xl text-gradient-forest">
        Juntos, somos +Fortes.
      </p>

      <!-- Purpose -->
      <p class="text-lg t-body/80 leading-relaxed max-w-2xl">
        Dar estrutura ao apoio que já existe ao redor de quem precisa mudar — transformando boa vontade em acompanhamento real.
      </p>

      <!-- Colors -->
      <div class="flex gap-3">
        {['#2D6A4F', '#40916C', '#1B4332', '#F4845F', '#FFB703', '#90E0EF'].map((color) => (
          <div class="w-12 h-12 rounded-lg" style={`background-color: ${color};`}></div>
        ))}
      </div>

      <!-- Typography -->
      <div class="space-y-2 pt-4 border-t t-border/30">
        <p class="font-display font-bold text-2xl t-heading">Outfit — Display</p>
        <p class="font-body text-lg t-muted">Plus Jakarta Sans — Body</p>
        <p class="font-mono text-sm t-muted/60">JetBrains Mono — Data</p>
      </div>
    </div>
  </Section>

  <!-- 02 Values -->
  <Section number="02" title="Valores" subtitle="O que nos guia">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3">
      {[
        { name: 'Presença', svg: 'M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78L12 21.23l8.84-8.84a5.5 5.5 0 000-7.78z' },
        { name: 'Honestidade', svg: 'M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8zM12 9a3 3 0 100 6 3 3 0 000-6z' },
        { name: 'Constância', svg: 'M13 2L3 14h9l-1 8 10-12h-9l1-8z' },
        { name: 'Confiança', svg: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z' },
        { name: 'Leveza', svg: 'M20.24 12.24a6 6 0 00-8.49-8.49L5 10.5V19h8.5zM16 8L2 22M17.5 15H9' },
      ].map((v) => (
        <div class="surface-card p-4 text-center">
          <div class="w-10 h-10 mx-auto mb-2 rounded-lg bg-brand-forest/10 flex items-center justify-center">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2D6A4F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d={v.svg} /></svg>
          </div>
          <span class="font-display font-bold text-sm t-heading">{v.name}</span>
        </div>
      ))}
    </div>
  </Section>

  <!-- 03 Manifesto -->
  <Section number="03" title="Manifesto">
    <div class="surface-elevated p-8 md:p-12 rounded-[20px]">
      <blockquote class="font-display text-2xl md:text-3xl t-heading leading-relaxed space-y-4">
        <p>"Ninguém muda sozinho.</p>
        <p>+Fortes existe porque acreditamos que as pessoas ao redor de quem está lutando por uma mudança precisam de um papel claro: estar junto sem invadir, apoiar sem sufocar, celebrar sem exagerar.</p>
        <p class="text-gradient-warm">Porque juntos, somos +Fortes."</p>
      </blockquote>
    </div>
  </Section>

</BrandbookLayout>
