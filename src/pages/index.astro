---
import BaseLayout from '@/layouts/BaseLayout.astro';
import StickyNav from '@/components/nav/StickyNav.astro';
import { brand } from '@/lib/brand';
import { navigation, getAllPages } from '@/lib/navigation';

const currentPath = Astro.url.pathname;
const totalPages = getAllPages().length;

const groupIcons = ['palette', 'puzzle', 'image'];
const groupDescriptions = [
  'Estratégia, identidade, fundamentos',
  'Componentes, padrões, templates',
  'Aplicações e contexto real',
];
---

<BaseLayout>
  <StickyNav currentPath={currentPath} />

  <main class="lg:ml-64 min-h-screen flex flex-col relative overflow-x-hidden">

    <!-- Background layers -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <!-- Dot grid pattern -->
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, #E6EDF3 1px, transparent 1px); background-size: 32px 32px;"></div>
      <!-- Radial glow (forest green) -->
      <div class="home-glow"></div>
      <!-- Secondary warm glow -->
      <div class="home-glow-warm"></div>
      <!-- Vignette -->
      <div class="absolute inset-0" style="background: radial-gradient(ellipse at center, transparent 40%, rgba(0,0,0,0.5) 100%);"></div>
    </div>

    <!-- Content -->
    <div class="flex-1 flex flex-col items-center justify-center px-4 sm:px-6 pt-24 lg:pt-20 pb-20 relative z-10">

      <!-- Hero -->
      <div class="w-full max-w-3xl mx-auto text-center">

        <!-- Animated "+" logo -->
        <div class="home-logo-wrap">
          <!-- Orbit ring -->
          <svg viewBox="0 0 140 140" fill="none" class="home-orbit w-full h-full">
            <circle cx="70" cy="70" r="65" stroke="currentColor" stroke-width="0.5" stroke-dasharray="8 6" />
            <circle cx="70" cy="70" r="48" stroke="currentColor" stroke-width="0.3" />
          </svg>
          <!-- "+" mark -->
          <div class="home-logo-mark">
            <span class="font-display font-bold text-3xl sm:text-4xl t-heading">+</span>
          </div>
        </div>

        <!-- Title -->
        <h1 class="home-title font-display font-bold text-4xl sm:text-5xl md:text-7xl lg:text-8xl t-heading leading-none tracking-tight">
          <span class="home-title-line" style="--delay: 0.2s">MAIS</span><br />
          <span class="home-title-line home-title-gradient" style="--delay: 0.4s">FORTES</span>
        </h1>

        <!-- Subtitle -->
        <div class="home-fade" style="--delay: 0.6s">
          <p class="font-mono text-[10px] sm:text-sm t-muted tracking-widest uppercase" style="margin-top: 1.25rem;">
            Brand Identity System
          </p>
        </div>

        <!-- Tagline -->
        <div class="home-fade" style="--delay: 0.8s">
          <p class="text-sm sm:text-lg t-body/80 max-w-xl mx-auto leading-relaxed" style="margin-top: 1.5rem;">
            {brand.purpose}
          </p>
        </div>

        <!-- Ticker -->
        <div class="home-fade overflow-hidden" style="--delay: 1s; margin-top: 2.5rem;">
          <div class="flex items-center gap-6 home-ticker font-mono text-xs t-muted uppercase tracking-widest whitespace-nowrap">
            {[...Array(2)].map(() => (
              <span class="flex items-center gap-6">
                <span>Jornada</span><span class="text-brand-forest">+</span>
                <span>Apoio</span><span class="text-brand-forest">+</span>
                <span>Check-in</span><span class="text-brand-forest">+</span>
                <span>Streak</span><span class="text-brand-forest">+</span>
                <span>Rede</span><span class="text-brand-forest">+</span>
                <span>Constância</span><span class="text-brand-forest">+</span>
                <span>Presença</span><span class="text-brand-forest">+</span>
                <span>Evolução</span><span class="text-brand-forest">+</span>
              </span>
            ))}
          </div>
        </div>

        <!-- Stats -->
        <div class="home-fade" style="--delay: 1.1s; margin-top: 2.5rem;">
          <div class="inline-flex items-center gap-4 sm:gap-6 md:gap-10 font-mono text-[10px] sm:text-xs t-muted px-4 sm:px-6 py-4 rounded-lg border t-border/30 t-surface/30 backdrop-blur-sm">
            <div class="text-center">
              <span class="t-heading text-xl sm:text-2xl font-display font-bold block home-counter">{totalPages}</span>
              <span style="margin-top: 0.125rem; display: block;">páginas</span>
            </div>
            <div class="w-px h-10 bg-brand-dark-border/50"></div>
            <div class="text-center">
              <span class="t-heading text-xl sm:text-2xl font-display font-bold block home-counter">{navigation.length}</span>
              <span style="margin-top: 0.125rem; display: block;">categorias</span>
            </div>
            <div class="w-px h-10 bg-brand-dark-border/50"></div>
            <div class="text-center">
              <span class="text-brand-forest text-xl sm:text-2xl font-display font-bold block home-counter">v{brand.version}</span>
              <span style="margin-top: 0.125rem; display: block;">edição</span>
            </div>
          </div>
        </div>

        <!-- Quick links -->
        <div class="home-fade" style="--delay: 1.3s; margin-top: 3rem;">
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 max-w-2xl mx-auto w-full">
            {navigation.map((nav, i) => {
              const firstPage = nav.pages[0];
              const href = firstPage.slug === '' ? `/${nav.slug}/` : `/${nav.slug}/${firstPage.slug}/`;
              return (
              <a
                href={href}
                class="group home-card relative p-5 rounded-lg border t-border/40 t-surface/40 backdrop-blur-sm hover:border-brand-forest/50 hover:t-surface/60 transition-all duration-300 overflow-hidden text-left"
              >
                <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-brand-forest/0 to-transparent group-hover:via-brand-forest/60 transition-all duration-500"></div>
                <div class="font-display font-bold text-sm t-heading group-hover:text-brand-forest transition-colors">
                  {nav.group}
                </div>
                <div class="font-mono text-[10px] t-muted" style="margin-top: 0.25rem;">
                  {groupDescriptions[i]}
                </div>
                <div class="font-mono text-[10px] t-muted/60" style="margin-top: 0.5rem;">
                  {nav.pages.length} páginas
                </div>
                <svg class="absolute bottom-3 right-3 w-4 h-4 text-brand-dark-border group-hover:text-brand-forest/50 group-hover:translate-x-0.5 transition-all" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
              </a>
            );})}
          </div>
        </div>
      </div>

      <!-- Footer -->
      <div class="home-fade" style="--delay: 1.5s; margin-top: auto; padding-top: 3rem; padding-bottom: 1rem;">
        <div class="font-mono text-[10px] t-muted text-center tracking-wider">
          Brand Identity System <span class="text-brand-dark-border">//</span> v{brand.version} <span class="text-brand-dark-border">//</span> {brand.year} <span class="text-brand-dark-border">//</span> {brand.edition}
        </div>
      </div>
    </div>

  </main>

  <style>
    /* Forest glow */
    .home-glow {
      position: absolute;
      top: 25%;
      left: 50%;
      transform: translateX(-50%);
      width: 100%;
      max-width: 800px;
      height: 400px;
      border-radius: 50%;
      background: radial-gradient(ellipse, rgba(45, 106, 79, 0.08) 0%, transparent 70%);
      animation: breathe 6s ease-in-out infinite;
    }
    .home-glow-warm {
      position: absolute;
      top: 50%;
      left: 60%;
      transform: translateX(-50%);
      width: 600px;
      height: 300px;
      border-radius: 50%;
      background: radial-gradient(ellipse, rgba(244, 132, 95, 0.04) 0%, transparent 70%);
      animation: breathe 8s ease-in-out 2s infinite;
    }
    @keyframes breathe {
      0%, 100% { opacity: 0.6; transform: translateX(-50%) scale(1); }
      50% { opacity: 1; transform: translateX(-50%) scale(1.1); }
    }

    /* Orbit ring */
    .home-logo-wrap {
      position: relative;
      display: inline-block;
      width: 100px;
      height: 100px;
      margin-bottom: 1.5rem;
    }
    @media (min-width: 640px) {
      .home-logo-wrap { width: 140px; height: 140px; margin-bottom: 2rem; }
    }
    .home-orbit {
      color: rgba(45, 106, 79, 0.2);
      animation: orbitSpin 30s linear infinite;
    }
    @keyframes orbitSpin {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }

    /* "+" mark */
    .home-logo-mark {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 56px;
      height: 56px;
      margin: auto;
      border-radius: 16px;
      background: #2D6A4F;
      box-shadow: 0 0 30px rgba(45, 106, 79, 0.4), 0 0 60px rgba(45, 106, 79, 0.15);
      animation: logoEntrance 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards, logoPulse 4s ease-in-out 1s infinite;
      opacity: 0;
      transform: scale(0.5);
    }
    @media (min-width: 640px) {
      .home-logo-mark { width: 72px; height: 72px; }
    }
    @keyframes logoEntrance {
      to { opacity: 1; transform: scale(1); }
    }
    @keyframes logoPulse {
      0%, 100% { box-shadow: 0 0 30px rgba(45, 106, 79, 0.4), 0 0 60px rgba(45, 106, 79, 0.15); }
      50% { box-shadow: 0 0 40px rgba(45, 106, 79, 0.6), 0 0 80px rgba(45, 106, 79, 0.25); }
    }

    /* Title animation */
    .home-title-line {
      display: inline-block;
      opacity: 0;
      transform: translateY(30px);
      animation: titleReveal 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      animation-delay: var(--delay, 0s);
    }
    @keyframes titleReveal {
      to { opacity: 1; transform: translateY(0); }
    }
    .home-title-gradient {
      background: linear-gradient(90deg, #2D6A4F, #40916C, #F4845F);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* Fade up */
    .home-fade {
      opacity: 0;
      transform: translateY(16px);
      animation: fadeUp 0.6s ease-out forwards;
      animation-delay: var(--delay, 0s);
    }
    @keyframes fadeUp {
      to { opacity: 1; transform: translateY(0); }
    }

    /* Ticker */
    .home-ticker {
      animation: tickerScroll 25s linear infinite;
    }
    @keyframes tickerScroll {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }

    /* Card hover */
    .home-card::after {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: 8px;
      opacity: 0;
      transition: opacity 0.3s;
      background: radial-gradient(circle at 50% 0%, rgba(45, 106, 79, 0.08) 0%, transparent 70%);
    }
    .home-card:hover::after { opacity: 1; }

    /* Counter pop */
    .home-counter {
      animation: counterPop 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      animation-delay: 1.2s;
      opacity: 0;
      transform: scale(0.5);
    }
    @keyframes counterPop {
      to { opacity: 1; transform: scale(1); }
    }
  </style>
</BaseLayout>
