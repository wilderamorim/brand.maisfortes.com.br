---
import BrandbookLayout from '@/layouts/BrandbookLayout.astro';
import Section from '@/components/layout/Section.astro';
---

<BrandbookLayout
  pageNumber="3.0"
  pageTitle="Logo"
  pageSubtitle="Sistema de logo, variantes, clear space e regras de uso."
  sectionsCount={4}
>

  <!-- 01 Primary Logo -->
  <Section number="01" title="Logo Primario" subtitle="Marca principal">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <!-- Dark background -->
      <div class="surface-elevated p-12 flex items-center justify-center">
        <div class="flex items-center gap-3">
          <div class="w-14 h-14 rounded-xl bg-brand-forest flex items-center justify-center shadow-glow-md">
            <span class="font-display font-bold text-3xl t-heading">+</span>
          </div>
          <span class="font-display font-bold text-4xl t-heading">Fortes</span>
        </div>
      </div>
      <!-- Light background -->
      <div class="p-12 flex items-center justify-center rounded-lg bg-white">
        <div class="flex items-center gap-3">
          <div class="w-14 h-14 rounded-xl bg-brand-forest flex items-center justify-center">
            <span class="font-display font-bold text-3xl t-heading">+</span>
          </div>
          <span class="font-display font-bold text-4xl text-brand-charcoal">Fortes</span>
        </div>
      </div>
    </div>
  </Section>

  <!-- 02 Variants -->
  <Section number="02" title="Variantes" subtitle="Adaptacoes por contexto">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <!-- Horizontal -->
      <div class="surface-card p-6 flex flex-col items-center gap-3">
        <div class="flex items-center gap-2">
          <div class="w-8 h-8 rounded-lg bg-brand-forest flex items-center justify-center">
            <span class="font-display font-bold text-lg t-heading">+</span>
          </div>
          <span class="font-display font-bold text-lg t-heading">Fortes</span>
        </div>
        <span class="font-mono text-[10px] t-muted">Horizontal</span>
      </div>
      <!-- Stacked -->
      <div class="surface-card p-6 flex flex-col items-center gap-3">
        <div class="flex flex-col items-center gap-1">
          <div class="w-10 h-10 rounded-lg bg-brand-forest flex items-center justify-center">
            <span class="font-display font-bold text-xl t-heading">+</span>
          </div>
          <span class="font-display font-bold text-sm t-heading">Fortes</span>
        </div>
        <span class="font-mono text-[10px] t-muted">Stacked</span>
      </div>
      <!-- Icon -->
      <div class="surface-card p-6 flex flex-col items-center gap-3">
        <div class="w-12 h-12 rounded-xl bg-brand-forest flex items-center justify-center shadow-glow">
          <span class="font-display font-bold text-2xl t-heading">+</span>
        </div>
        <span class="font-mono text-[10px] t-muted">Icon</span>
      </div>
      <!-- Monochrome -->
      <div class="surface-card p-6 flex flex-col items-center gap-3">
        <div class="flex items-center gap-2">
          <div class="w-8 h-8 rounded-lg bg-white flex items-center justify-center">
            <span class="font-display font-bold text-lg text-brand-night">+</span>
          </div>
          <span class="font-display font-bold text-lg t-heading">Fortes</span>
        </div>
        <span class="font-mono text-[10px] t-muted">Monochrome</span>
      </div>
    </div>
  </Section>

  <!-- 03 Clear Space -->
  <Section number="03" title="Clear Space" subtitle="Espaco minimo ao redor">
    <div class="surface-card p-8 flex items-center justify-center">
      <div class="relative">
        <div class="border-2 border-dashed border-brand-forest/30 p-8 rounded-xl">
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 rounded-xl bg-brand-forest flex items-center justify-center">
              <span class="font-display font-bold text-2xl t-heading">+</span>
            </div>
            <span class="font-display font-bold text-3xl t-heading">Fortes</span>
          </div>
        </div>
        <span class="absolute -top-6 left-1/2 -translate-x-1/2 font-mono text-[10px] text-brand-forest">
          min = altura do icone
        </span>
      </div>
    </div>
  </Section>

  <!-- 04 Don'ts -->
  <Section number="04" title="Uso Incorreto" subtitle="O que nao fazer com o logo">
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      {[
        'Nao rotacione',
        'Nao mude as cores',
        'Nao adicione sombras',
        'Nao distorca proporcoes',
        'Nao use em fundos sem contraste',
        'Nao separe o + do Fortes',
      ].map((rule) => (
        <div class="surface-card p-4 text-center border-brand-coral/20">
          <div class="w-10 h-10 mx-auto rounded-full bg-brand-coral/10 flex items-center justify-center mb-2">
            <span class="text-brand-coral text-lg">✕</span>
          </div>
          <p class="text-xs t-muted">{rule}</p>
        </div>
      ))}
    </div>
  </Section>

</BrandbookLayout>
