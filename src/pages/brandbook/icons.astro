---
import BrandbookLayout from '@/layouts/BrandbookLayout.astro';
import Section from '@/components/layout/Section.astro';
---

<BrandbookLayout
  pageNumber="4.0"
  pageTitle="Icons"
  pageSubtitle="Sistema de ícones stroke-based. Lucide Icons como biblioteca base."
  sectionsCount={3}
>

  <Section number="01" title="Estilo" subtitle="Especificações do sistema de ícones">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {[
        { label: 'Tipo', value: 'Outlined (stroke)' },
        { label: 'Stroke', value: '1.5px' },
        { label: 'Grid', value: '24px base' },
        { label: 'Radius', value: '2px' },
      ].map((spec) => (
        <div class="surface-card p-4 text-center">
          <span class="font-mono text-xs t-muted block mb-1">{spec.label}</span>
          <span class="font-display font-bold t-heading">{spec.value}</span>
        </div>
      ))}
    </div>
  </Section>

  <Section number="02" title="Ícones Core" subtitle="Ícones essenciais do +Fortes">
    <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 gap-3">
      {[
        { name: 'check-circle', label: 'Check-in', svg: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z' },
        { name: 'flame', label: 'Streak', svg: 'M12 12c0-3 2.5-6 2.5-6S17 9 17 12a5 5 0 01-10 0c0-1 .5-2 1.5-3' },
        { name: 'heart', label: 'Apoio', svg: 'M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78L12 21.23l8.84-8.84a5.5 5.5 0 000-7.78z' },
        { name: 'users', label: 'Rede', svg: 'M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2M9 7a4 4 0 100-8 4 4 0 000 8zM23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75' },
        { name: 'shield', label: 'Privacidade', svg: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z' },
        { name: 'bell', label: 'Notificação', svg: 'M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 01-3.46 0' },
        { name: 'trending-up', label: 'Progresso', svg: 'M23 6l-9.5 9.5-5-5L1 18' },
        { name: 'calendar', label: 'Histórico', svg: 'M19 4H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2V6a2 2 0 00-2-2zM16 2v4M8 2v4M3 10h18' },
        { name: 'message-circle', label: 'Mensagem', svg: 'M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z' },
        { name: 'star', label: 'Conquista', svg: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z' },
      ].map((icon) => (
        <div class="surface-card p-4 text-center group hover:border-brand-forest/40 transition-colors">
          <div class="w-12 h-12 mx-auto mb-2 flex items-center justify-center">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="t-muted group-hover:text-brand-forest transition-colors">
              <path d={icon.svg} />
            </svg>
          </div>
          <span class="text-xs t-heading block">{icon.label}</span>
          <span class="font-mono text-[10px] t-muted/60">{icon.name}</span>
        </div>
      ))}
    </div>
  </Section>

  <Section number="03" title="Regras" subtitle="Consistência no uso">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="surface-card p-5">
        <h4 class="font-mono text-xs text-brand-forest uppercase tracking-widest mb-3">Fazer</h4>
        <ul class="space-y-2 text-sm t-heading">
          <li class="flex gap-2"><span class="text-brand-forest">+</span> Manter stroke de 1.5px em todos os tamanhos</li>
          <li class="flex gap-2"><span class="text-brand-forest">+</span> Usar ícones da biblioteca Lucide</li>
          <li class="flex gap-2"><span class="text-brand-forest">+</span> Manter estilo outlined consistente</li>
          <li class="flex gap-2"><span class="text-brand-forest">+</span> Alinhar ícones ao grid de 24px</li>
        </ul>
      </div>
      <div class="surface-card p-5">
        <h4 class="font-mono text-xs text-brand-coral uppercase tracking-widest mb-3">Evitar</h4>
        <ul class="space-y-2 text-sm t-muted">
          <li class="flex gap-2"><span class="text-brand-coral">-</span> Misturar ícones filled com outlined</li>
          <li class="flex gap-2"><span class="text-brand-coral">-</span> Alterar proporções dos ícones</li>
          <li class="flex gap-2"><span class="text-brand-coral">-</span> Usar ícones de bibliotecas diferentes</li>
          <li class="flex gap-2"><span class="text-brand-coral">-</span> Ícones menores que 16px</li>
        </ul>
      </div>
    </div>
  </Section>

</BrandbookLayout>
