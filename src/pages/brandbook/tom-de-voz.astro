---
import BrandbookLayout from '@/layouts/BrandbookLayout.astro';
import Section from '@/components/layout/Section.astro';
---

<BrandbookLayout
  pageNumber="6.0"
  pageTitle="Tom de Voz"
  pageSubtitle="Guia de copywriting, exemplos e regras de comunicação da marca."
  sectionsCount={4}
>

  <Section number="01" title="Princípios de Escrita" subtitle="Como escrevemos">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {[
        { title: 'Curto e direto', example: '"Ei, como foi hoje?" em vez de "Gostaríamos de saber como foi o seu dia de hoje."' },
        { title: 'Primeira pessoa do plural', example: '"Juntos, somos +Fortes" — sempre coletivo, nunca solitário.' },
        { title: 'Sem jargão clínico', example: '"Dia difícil" em vez de "episódio de recaída". "Tropeço" em vez de "falha".' },
        { title: 'Acolhimento antes de ação', example: '"Tudo bem. O importante é voltar." — primeiro valida, depois motiva.' },
      ].map((p) => (
        <div class="surface-card p-5 space-y-2">
          <h4 class="font-display font-bold t-heading">{p.title}</h4>
          <p class="text-sm t-muted italic">{p.example}</p>
        </div>
      ))}
    </div>
  </Section>

  <Section number="02" title="Reescrita de Exemplos" subtitle="Antes vs. Depois">
    <div class="space-y-3">
      {[
        { before: 'Você falhou no check-in de ontem.', after: 'Ontem passou sem check-in. Tudo bem — hoje é um novo dia.' },
        { before: 'Parabéns! Você completou 7 dias sem recaída!', after: '1 semana firme! Você tá criando um hábito.' },
        { before: 'Seu monitor Maria foi notificado da sua inatividade.', after: 'Maria sentiu sua falta. Que tal fazer o check-in de hoje?' },
        { before: 'Erro ao processar requisição. Tente novamente mais tarde.', after: 'Algo deu errado. Tenta de novo?' },
        { before: 'Cadastro realizado com sucesso. Bem-vindo à plataforma.', after: 'Pronto! Sua jornada começa agora.' },
      ].map((item) => (
        <div class="surface-card p-4 grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <span class="font-mono text-[10px] text-brand-coral uppercase tracking-widest">Antes</span>
            <p class="text-sm t-muted mt-1 line-through decoration-brand-coral/30">{item.before}</p>
          </div>
          <div>
            <span class="font-mono text-[10px] text-brand-forest uppercase tracking-widest">Depois</span>
            <p class="text-sm t-heading mt-1">{item.after}</p>
          </div>
        </div>
      ))}
    </div>
  </Section>

  <Section number="03" title="Tom por Canal" subtitle="Adaptação de voz por contexto">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {[
        { canal: 'App (UI)', tom: 'Íntimo, curto', exemplo: '"Como foi hoje?"', nota: 'Máximo 2 linhas por mensagem' },
        { canal: 'Push notification', tom: 'Gentil, não invasivo', exemplo: '"Seu check-in está disponível"', nota: 'Nunca culpar ou pressionar' },
        { canal: 'Email', tom: 'Caloroso, pessoal', exemplo: '"Oi [nome], sua semana foi incrível"', nota: 'Sempre personalizado com nome' },
      ].map((c) => (
        <div class="surface-card p-5 space-y-3">
          <h4 class="font-display font-bold t-heading">{c.canal}</h4>
          <span class="font-mono text-xs text-brand-forest">{c.tom}</span>
          <p class="text-sm t-heading italic">"{c.exemplo}"</p>
          <p class="text-[10px] t-muted">{c.nota}</p>
        </div>
      ))}
    </div>
  </Section>

  <Section number="04" title="Checklist de Copy" subtitle="Antes de publicar, verifique">
    <div class="surface-card p-6">
      <ul class="space-y-3">
        {[
          'Parece um amigo falando? (não uma empresa)',
          'É curto o suficiente? (corte pela metade)',
          'Acolhe antes de cobrar?',
          'Evita palavras da lista "Evitamos"?',
          'Um protagonista em dia difícil se sentiria julgado lendo isso?',
          'Um apoiador saberia o que fazer ao ler isso?',
        ].map((item) => (
          <li class="flex items-start gap-3 text-sm">
            <div class="w-5 h-5 rounded border border-brand-forest/40 flex items-center justify-center shrink-0 mt-0.5">
              <span class="text-brand-forest text-xs">?</span>
            </div>
            <span class="t-body">{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </Section>

</BrandbookLayout>
