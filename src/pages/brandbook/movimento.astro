---
import BrandbookLayout from '@/layouts/BrandbookLayout.astro';
import Section from '@/components/layout/Section.astro';
import { brand } from '@/lib/brand';
---

<BrandbookLayout
  pageNumber="1.0"
  pageTitle="Movimento"
  pageSubtitle="Estratégia completa da marca: manifesto, propósito, BrandScript, voz e contrato."
  sectionsCount={7}
>

  <!-- 01 Manifesto -->
  <Section number="01" title="Manifesto">
    <div class="surface-elevated p-8 md:p-12 space-y-6">
      <p class="font-display font-bold text-3xl md:text-4xl t-heading leading-snug">
        Ninguém muda sozinho.
      </p>
      <div class="t-body/80 leading-relaxed space-y-4 max-w-3xl text-lg">
        <p>A gente sabe que a mudança é difícil. Que tem dia que você não vai querer nem abrir o app. Que a vontade de desistir aparece mais do que a vontade de continuar.</p>
        <p>Mas a gente sabe também que quando alguém está olhando por você — de verdade, sem julgamento, sem cobrança pesada — fica mais fácil dar o próximo passo.</p>
        <p>+Fortes existe porque acreditamos que as pessoas ao redor de quem está lutando por uma mudança precisam de um papel claro: estar junto sem invadir, apoiar sem sufocar, celebrar sem exagerar.</p>
        <p class="font-display font-bold text-xl text-brand-forest">Porque juntos, somos +Fortes.</p>
      </div>
    </div>
  </Section>

  <!-- 02 BrandScript SB7 -->
  <Section number="02" title="BrandScript (SB7)" subtitle="Framework StoryBrand">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="surface-card p-5">
        <span class="font-mono text-xs text-brand-forest">01 — Personagem</span>
        <p class="t-heading mt-2">{brand.brandscript.character}</p>
      </div>
      <div class="surface-card p-5 space-y-2">
        <span class="font-mono text-xs text-brand-forest">02 — Problema</span>
        <div class="space-y-1 mt-2">
          <p class="text-sm"><span class="t-muted">Externo:</span> <span class="t-heading">{brand.brandscript.problem.external}</span></p>
          <p class="text-sm"><span class="t-muted">Interno:</span> <span class="t-heading">{brand.brandscript.problem.internal}</span></p>
          <p class="text-sm"><span class="t-muted">Filosófico:</span> <span class="t-heading">{brand.brandscript.problem.philosophical}</span></p>
        </div>
      </div>
      <div class="surface-card p-5 space-y-2">
        <span class="font-mono text-xs text-brand-forest">03 — Guia</span>
        <div class="space-y-1 mt-2">
          <p class="text-sm"><span class="t-muted">Empatia:</span> <span class="t-heading">{brand.brandscript.guide.empathy}</span></p>
          <p class="text-sm"><span class="t-muted">Autoridade:</span> <span class="t-heading">{brand.brandscript.guide.authority}</span></p>
        </div>
      </div>
      <div class="surface-card p-5">
        <span class="font-mono text-xs text-brand-forest">04 — Plano</span>
        <ol class="mt-2 space-y-1">
          {brand.brandscript.plan.map((step, i) => (
            <li class="text-sm t-heading"><span class="t-muted font-mono text-xs mr-2">{i + 1}.</span>{step}</li>
          ))}
        </ol>
      </div>
      <div class="surface-card p-5">
        <span class="font-mono text-xs text-brand-forest">05 — Chamada à Ação</span>
        <div class="mt-2 space-y-2">
          <div class="inline-block px-4 py-2 bg-brand-forest rounded-lg t-heading text-sm font-semibold">{brand.brandscript.cta.direct}</div>
          <p class="text-sm t-muted">{brand.brandscript.cta.transitional}</p>
        </div>
      </div>
      <div class="surface-card p-5 space-y-3">
        <div>
          <span class="font-mono text-xs text-brand-forest">06 — Sucesso</span>
          <p class="text-sm t-heading mt-1">{brand.brandscript.success}</p>
        </div>
        <div>
          <span class="font-mono text-xs text-brand-coral">07 — Fracasso</span>
          <p class="text-sm t-muted mt-1">{brand.brandscript.failure}</p>
        </div>
      </div>
    </div>
  </Section>

  <!-- 03 Voz & Tom -->
  <Section number="03" title="Voz & Tom" subtitle="Como a marca fala">
    <div class="space-y-4">
      <div class="surface-card p-6">
        <h4 class="font-mono text-xs t-muted uppercase tracking-widest mb-4">Somos</h4>
        <div class="flex flex-wrap gap-2">
          {brand.voice.traits.map((t) => (
            <span class="px-3 py-1.5 rounded-full bg-brand-forest/15 text-brand-forest text-sm font-medium border border-brand-forest/30">{t}</span>
          ))}
        </div>
      </div>
      <div class="surface-card p-6">
        <h4 class="font-mono text-xs t-muted uppercase tracking-widest mb-4">Não somos</h4>
        <div class="flex flex-wrap gap-2">
          {brand.voice.doNot.map((t) => (
            <span class="px-3 py-1.5 rounded-full bg-brand-coral/10 text-brand-coral text-sm border border-brand-coral/20">{t}</span>
          ))}
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="surface-card p-6">
          <h4 class="font-mono text-xs text-brand-forest mb-2">Parecemos com</h4>
          <p class="t-heading">{brand.voice.sounds_like}</p>
        </div>
        <div class="surface-card p-6">
          <h4 class="font-mono text-xs text-brand-coral mb-2">Evitar parecer com</h4>
          <p class="t-muted">{brand.voice.avoidSounding}</p>
        </div>
      </div>
    </div>
  </Section>

  <!-- 04 Tom por contexto -->
  <Section number="04" title="Tom por Contexto" subtitle="Exemplos reais de comunicação">
    <div class="space-y-4">
      {[
        { context: 'Check-in — Score 5', msg: 'Dia incrível! Sua rede vai adorar ver isso.', tone: 'Celebração' },
        { context: 'Check-in — Score 3', msg: 'Tudo bem. Nem todo dia precisa ser incrível.', tone: 'Acolhimento' },
        { context: 'Check-in — Score 1', msg: 'Dias assim fazem parte. Amanhã é um novo dia. Sua rede está com você.', tone: 'Empatia' },
        { context: 'Streak 7 dias', msg: '1 semana! Você tá criando um hábito.', tone: 'Motivação' },
        { context: 'Streak quebrado', msg: 'Tudo bem. O importante é voltar. Bora?', tone: 'Leveza' },
        { context: 'Convite para apoiador', msg: '[Nome] confiou em você para acompanhar essa jornada.', tone: 'Confiança' },
        { context: 'Alerta de inatividade', msg: '[Nome] não fez check-in há 2 dias. Que tal mandar uma mensagem?', tone: 'Cuidado' },
        { context: 'Boas-vindas', msg: 'Bem-vindo ao +Fortes. Aqui, ninguém muda sozinho.', tone: 'Acolhimento' },
      ].map((item) => (
        <div class="surface-card p-4 flex flex-col md:flex-row md:items-center gap-3">
          <div class="shrink-0 w-40">
            <span class="font-mono text-xs t-muted">{item.context}</span>
          </div>
          <div class="flex-1">
            <p class="t-heading text-sm">"{item.msg}"</p>
          </div>
          <div class="shrink-0">
            <span class="font-mono text-[10px] px-2 py-1 rounded bg-brand-forest/10 text-brand-forest">{item.tone}</span>
          </div>
        </div>
      ))}
    </div>
  </Section>

  <!-- 05 Usuarios -->
  <Section number="05" title="Usuários" subtitle="Quem usa o +Fortes">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {Object.values(brand.users).map((u) => (
        <div class="surface-card p-5 space-y-2">
          <h4 class="font-display font-bold t-heading">{u.label}</h4>
          <p class="text-sm t-muted">{u.description}</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- 06 Vocabulario -->
  <Section number="06" title="Vocabulário" subtitle="Palavras que usamos e evitamos">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="surface-card p-6">
        <h4 class="font-mono text-xs text-brand-forest uppercase tracking-widest mb-4">Usamos</h4>
        <div class="space-y-2">
          {[
            ['Protagonista', 'Quem está na jornada'],
            ['Apoiador', 'Quem acompanha'],
            ['Check-in', 'Registro diário'],
            ['Jornada', 'O processo de mudança'],
            ['Streak', 'Sequência de dias'],
            ['Dia difícil', 'Em vez de "falha"'],
            ['Tropeço', 'Em vez de "recaída"'],
          ].map(([word, meaning]) => (
            <div class="flex items-center gap-3">
              <span class="text-sm font-semibold t-heading w-28">{word}</span>
              <span class="text-xs t-muted">{meaning}</span>
            </div>
          ))}
        </div>
      </div>
      <div class="surface-card p-6">
        <h4 class="font-mono text-xs text-brand-coral uppercase tracking-widest mb-4">Evitamos</h4>
        <div class="space-y-2">
          {[
            ['Paciente', 'Usar "protagonista"'],
            ['Monitorar', 'Usar "acompanhar"'],
            ['Controle', 'Usar "acompanhamento"'],
            ['Fracasso', 'Usar "dia difícil"'],
            ['Recaída', 'Usar "tropeço"'],
            ['Viciado', 'Usar "pessoa em jornada"'],
            ['Supervisão', 'Usar "presença"'],
          ].map(([word, alt]) => (
            <div class="flex items-center gap-3">
              <span class="text-sm text-brand-coral line-through w-28">{word}</span>
              <span class="text-xs t-muted">{alt}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </Section>

  <!-- 07 Contrato da Marca -->
  <Section number="07" title="Contrato da Marca" subtitle="O que +Fortes sempre faz e nunca faz">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="surface-card p-6">
        <h4 class="font-mono text-xs text-brand-forest uppercase tracking-widest mb-4">Sempre</h4>
        <ul class="space-y-2">
          {[
            'Coloca o protagonista no controle',
            'Trata dias ruins com acolhimento',
            'Mantém dados privados por padrão',
            'Usa linguagem simples e humana',
            'Celebra consistência, não perfeição',
          ].map((item) => (
            <li class="flex items-start gap-2 text-sm t-heading">
              <span class="text-brand-forest mt-0.5">+</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="surface-card p-6">
        <h4 class="font-mono text-xs text-brand-coral uppercase tracking-widest mb-4">Nunca</h4>
        <ul class="space-y-2">
          {[
            'Julga o protagonista',
            'Compartilha dados sem consentimento',
            'Usa linguagem clínica',
            'Gamifica o sofrimento',
            'Pressiona para performance',
            'Vende dados ou mostra anúncios',
          ].map((item) => (
            <li class="flex items-start gap-2 text-sm t-muted">
              <span class="text-brand-coral mt-0.5">-</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </Section>

</BrandbookLayout>
