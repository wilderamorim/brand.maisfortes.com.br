---
import BrandbookLayout from '@/layouts/BrandbookLayout.astro';
import Section from '@/components/layout/Section.astro';
import ColorSwatch from '@/components/brand/ColorSwatch.astro';
import ArchetypeCard from '@/components/brand/ArchetypeCard.astro';
import { brand } from '@/lib/brand';
---

<BrandbookLayout
  pageNumber="0.0"
  pageTitle="Guidelines"
  pageSubtitle="Visao geral da identidade +Fortes. Tipografia, paleta, construcao da marca, manifesto, simbolos, naming e posicionamento."
  sectionsCount={8}
>

  <!-- 01 Manifesto -->
  <Section number="01" title="Manifesto" subtitle="O que acreditamos">
    <div class="surface-elevated p-8 space-y-4">
      <blockquote class="font-display text-xl md:text-2xl t-heading leading-relaxed italic">
        "Ninguem muda sozinho."
      </blockquote>
      <p class="t-body/80 leading-relaxed max-w-3xl">
        {brand.manifesto}
      </p>
    </div>
  </Section>

  <!-- 02 Proposito -->
  <Section number="02" title="Proposito" subtitle="Por que existimos">
    <div class="surface-card p-6">
      <p class="text-lg t-heading font-body font-medium leading-relaxed">{brand.purpose}</p>
    </div>
  </Section>

  <!-- 03 Valores -->
  <Section number="03" title="Valores" subtitle="O que nos guia">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {brand.values.map((v) => (
        <div class="surface-card p-5 space-y-2">
          <h4 class="font-display font-bold t-heading">{v.name}</h4>
          <p class="text-sm t-muted">{v.description}</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- 04 Typography -->
  <Section number="04" title="Typography" subtitle="Sistema tipografico">
    <div class="space-y-6">
      <!-- Display -->
      <div class="surface-card p-6">
        <div class="flex items-center justify-between mb-4">
          <span class="font-mono text-xs text-brand-forest">{brand.typography.display.family}</span>
          <span class="font-mono text-[10px] t-muted">Display / Headlines</span>
        </div>
        <p class="font-display font-bold text-4xl md:text-6xl t-heading leading-tight">
          Juntos, somos +Fortes
        </p>
        <p class="font-display text-lg t-muted mt-2">
          Aa Bb Cc Dd Ee Ff Gg Hh Ii Jj Kk Ll Mm Nn Oo Pp Qq Rr Ss Tt Uu Vv Ww Xx Yy Zz
        </p>
        <div class="flex gap-4 mt-4 font-mono text-xs t-muted">
          {brand.typography.display.weights.map((w) => (
            <span class="px-2 py-1 rounded bg-brand-dark-border/30">{w}</span>
          ))}
        </div>
      </div>

      <!-- Body -->
      <div class="surface-card p-6">
        <div class="flex items-center justify-between mb-4">
          <span class="font-mono text-xs text-brand-forest">{brand.typography.body.family}</span>
          <span class="font-mono text-[10px] t-muted">Body / UI</span>
        </div>
        <p class="font-body text-lg t-heading leading-relaxed">
          A mudanca e dificil. Tem dia que voce nao vai querer nem abrir o app. Mas quando alguem esta olhando por voce, fica mais facil dar o proximo passo.
        </p>
        <p class="font-body text-base t-muted mt-2">
          Aa Bb Cc Dd Ee Ff Gg Hh Ii Jj Kk Ll Mm Nn Oo Pp Qq Rr Ss Tt Uu Vv Ww Xx Yy Zz 0123456789
        </p>
        <div class="flex gap-4 mt-4 font-mono text-xs t-muted">
          {brand.typography.body.weights.map((w) => (
            <span class="px-2 py-1 rounded bg-brand-dark-border/30">{w}</span>
          ))}
        </div>
      </div>

      <!-- Mono -->
      <div class="surface-card p-6">
        <div class="flex items-center justify-between mb-4">
          <span class="font-mono text-xs text-brand-forest">{brand.typography.mono.family}</span>
          <span class="font-mono text-[10px] t-muted">Mono / Data</span>
        </div>
        <p class="font-mono text-4xl font-bold t-heading">
          30 <span class="text-brand-forest text-lg">dias seguidos</span>
        </p>
        <p class="font-mono text-base t-muted mt-2">
          0123456789 . : / - + = # @ { } [ ] ( )
        </p>
      </div>
    </div>
  </Section>

  <!-- 05 Color Palette -->
  <Section number="05" title="Color Palette" subtitle="Identidade cromatica">
    <div class="space-y-6">
      <!-- Primary -->
      <div>
        <h4 class="font-mono text-xs t-muted uppercase tracking-widest mb-3">Cores Primarias</h4>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
          <ColorSwatch name={brand.colors.forest.name} hex={brand.colors.forest.hex} rgb={brand.colors.forest.rgb} usage={brand.colors.forest.usage} token={brand.colors.forest.token} large />
          <ColorSwatch name={brand.colors.forestLight.name} hex={brand.colors.forestLight.hex} rgb={brand.colors.forestLight.rgb} usage={brand.colors.forestLight.usage} token={brand.colors.forestLight.token} />
          <ColorSwatch name={brand.colors.forestDark.name} hex={brand.colors.forestDark.hex} rgb={brand.colors.forestDark.rgb} usage={brand.colors.forestDark.usage} token={brand.colors.forestDark.token} />
        </div>
      </div>

      <!-- Secondary -->
      <div>
        <h4 class="font-mono text-xs t-muted uppercase tracking-widest mb-3">Cores Secundarias</h4>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
          <ColorSwatch name={brand.colors.coral.name} hex={brand.colors.coral.hex} rgb={brand.colors.coral.rgb} usage={brand.colors.coral.usage} token={brand.colors.coral.token} />
          <ColorSwatch name={brand.colors.amber.name} hex={brand.colors.amber.hex} rgb={brand.colors.amber.rgb} usage={brand.colors.amber.usage} token={brand.colors.amber.token} />
          <ColorSwatch name={brand.colors.sky.name} hex={brand.colors.sky.hex} rgb={brand.colors.sky.rgb} usage={brand.colors.sky.usage} token={brand.colors.sky.token} />
        </div>
      </div>

      <!-- Dark neutrals -->
      <div>
        <h4 class="font-mono text-xs t-muted uppercase tracking-widest mb-3">Neutros — Dark Mode</h4>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
          <ColorSwatch name={brand.colors.night.name} hex={brand.colors.night.hex} usage={brand.colors.night.usage} token={brand.colors.night.token} />
          <ColorSwatch name={brand.colors.darkSurface.name} hex={brand.colors.darkSurface.hex} usage={brand.colors.darkSurface.usage} token={brand.colors.darkSurface.token} />
        </div>
      </div>

      <!-- Light neutrals -->
      <div>
        <h4 class="font-mono text-xs t-muted uppercase tracking-widest mb-3">Neutros — Light Mode</h4>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
          <ColorSwatch name={brand.colors.white.name} hex={brand.colors.white.hex} usage={brand.colors.white.usage} token={brand.colors.white.token} />
          <ColorSwatch name={brand.colors.snow.name} hex={brand.colors.snow.hex} usage={brand.colors.snow.usage} token={brand.colors.snow.token} />
          <ColorSwatch name={brand.colors.charcoal.name} hex={brand.colors.charcoal.hex} usage={brand.colors.charcoal.usage} token={brand.colors.charcoal.token} />
        </div>
      </div>
    </div>
  </Section>

  <!-- 06 Naming -->
  <Section number="06" title="Naming & Concept" subtitle="A construcao do nome">
    <div class="surface-card p-6 space-y-4">
      <div class="flex items-center gap-4">
        <div class="w-16 h-16 rounded-xl bg-brand-forest flex items-center justify-center shadow-glow-md">
          <span class="font-display font-bold text-3xl t-heading">+</span>
        </div>
        <div>
          <h4 class="font-display font-bold text-2xl t-heading">+Fortes</h4>
          <p class="font-mono text-xs t-muted">maisfortes.com.br</p>
        </div>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 pt-4 border-t t-border/30">
        <div class="text-center p-3">
          <span class="font-display font-bold text-3xl text-brand-forest">+</span>
          <p class="text-xs t-muted mt-1">Adicao</p>
        </div>
        <div class="text-center p-3">
          <span class="font-display font-bold text-3xl text-brand-coral">+</span>
          <p class="text-xs t-muted mt-1">Positividade</p>
        </div>
        <div class="text-center p-3">
          <span class="font-display font-bold text-3xl text-brand-amber">+</span>
          <p class="text-xs t-muted mt-1">Saude</p>
        </div>
        <div class="text-center p-3">
          <span class="font-display font-bold text-3xl text-brand-sky">+</span>
          <p class="text-xs t-muted mt-1">Conexao</p>
        </div>
      </div>
    </div>
  </Section>

  <!-- 07 Positioning -->
  <Section number="07" title="Posicionamento" subtitle="Como nos posicionamos">
    <div class="space-y-4">
      <div class="surface-elevated p-6">
        <p class="t-heading leading-relaxed">{brand.positioning.statement}</p>
      </div>
      <div class="surface-card p-6">
        <h4 class="font-mono text-xs t-muted uppercase tracking-widest mb-3">Inimigo da Marca</h4>
        <p class="font-display font-bold text-xl text-brand-coral">{brand.positioning.enemy}</p>
      </div>
      <div class="surface-card p-6">
        <h4 class="font-mono text-xs t-muted uppercase tracking-widest mb-3">Taglines</h4>
        <div class="space-y-2">
          {brand.positioning.taglines.map((t, i) => (
            <div class="flex items-center gap-3">
              <span class="font-mono text-xs text-brand-forest">{String(i + 1).padStart(2, '0')}</span>
              <span class:list={['font-display font-bold', i === 0 ? 'text-xl t-heading' : 'text-lg t-muted']}>{t}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </Section>

  <!-- 08 Archetypes -->
  <Section number="08" title="Arquetipos" subtitle="DNA da marca">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <ArchetypeCard {...brand.archetypes.primary} isPrimary />
      <ArchetypeCard {...brand.archetypes.secondary} />
    </div>
    <div class="surface-card p-6 mt-4">
      <h4 class="font-display font-bold t-heading mb-2">A combinacao +Fortes</h4>
      <p class="t-body/80 leading-relaxed">
        Cuida sem subestimar. Motiva sem pressionar. Acolhe sem ser passivo.
        O Cuidador da o abraco. O Heroi da a forca. Juntos: "Eu sei que e dificil, mas eu to aqui e voce consegue."
      </p>
    </div>
  </Section>

</BrandbookLayout>

