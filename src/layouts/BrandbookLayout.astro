---
import BaseLayout from './BaseLayout.astro';
import StickyNav from '@/components/nav/StickyNav.astro';
import PageHeader from '@/components/layout/PageHeader.astro';
import Footer from '@/components/layout/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  pageNumber?: string;
  pageTitle: string;
  pageSubtitle?: string;
  sectionsCount?: number;
}

const { title, description, pageNumber, pageTitle, pageSubtitle, sectionsCount } = Astro.props;
const currentPath = Astro.url.pathname;

const fullTitle = title || `${pageTitle} — +Fortes Brand System`;
---

<BaseLayout title={fullTitle} description={description}>
  <StickyNav currentPath={currentPath} />

  <main class="lg:ml-64 min-h-screen">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-12 pt-20 lg:pt-4 pb-8">
      <PageHeader
        number={pageNumber}
        title={pageTitle}
        subtitle={pageSubtitle}
        sectionsCount={sectionsCount}
      />
      <slot />
      <Footer />
    </div>
  </main>
</BaseLayout>
