---
import { brand } from '@/lib/brand';
---

<footer class="mt-24 py-8" style="border-top: 1px solid var(--theme-border-alpha);">
  <div class="flex flex-col md:flex-row items-center justify-between gap-4">
    <div class="font-mono text-xs t-muted tracking-wider">
      Brand Identity System <span class="opacity-30">//</span> v{brand.version} <span class="opacity-30">//</span> {brand.name}
    </div>
    <div class="flex items-center gap-6">
      <a href={brand.ecosystem.website.url} target="_blank" rel="noopener" class="t-muted hover:text-brand-forest transition-colors text-xs font-mono">
        Website
      </a>
    </div>
  </div>
</footer>
