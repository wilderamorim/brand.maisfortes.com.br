---
interface Props {
  number?: string;
  title: string;
  subtitle?: string;
  sectionsCount?: number;
}

const { number, title, subtitle, sectionsCount } = Astro.props;
---

<header class="pt-8 pb-12 mb-12 border-subtle" style="border-bottom: 1px solid var(--theme-border-alpha);">
  {number && (
    <span class="section-number mb-2 block">{number}</span>
  )}
  <h1 class="font-display font-bold text-4xl md:text-5xl lg:text-6xl t-heading leading-tight">
    {title}
  </h1>
  {subtitle && (
    <p class="mt-3 text-lg t-muted max-w-2xl">{subtitle}</p>
  )}
  <div class="page-meta mt-4 flex items-center gap-3">
    {sectionsCount && <span>{sectionsCount} sections</span>}
    <span class="t-muted opacity-30">//</span>
    <span>2026</span>
    <span class="t-muted opacity-30">//</span>
    <span>Warm Light Edition</span>
  </div>
</header>
