---
interface Props {
  number: string;
  title: string;
  href: string;
  active?: boolean;
}

const { number, title, href, active = false } = Astro.props;
---

<a
  href={href}
  class:list={[
    'group flex items-center gap-3 px-4 py-2 text-sm transition-all duration-200',
    active
      ? 't-heading border-l-2 border-brand-forest nav-item-active'
      : 't-muted border-l-2 border-transparent nav-item-inactive',
  ]}
>
  <span class:list={[
    'font-mono text-xs w-8 shrink-0',
    active ? 'text-brand-forest' : 't-muted opacity-60 group-hover:opacity-100',
  ]}>
    {number}
  </span>
  <span class="truncate">{title}</span>
</a>
