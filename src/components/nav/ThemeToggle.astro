---
---

<button
  class="theme-toggle flex items-center gap-2 px-3 py-1.5 rounded-lg text-xs font-mono transition-all duration-200 border"
  aria-label="Alternar tema"
>
  <svg class="theme-icon-sun w-4 h-4 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="5" />
    <line x1="12" y1="1" x2="12" y2="3" />
    <line x1="12" y1="21" x2="12" y2="23" />
    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
    <line x1="1" y1="12" x2="3" y2="12" />
    <line x1="21" y1="12" x2="23" y2="12" />
    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
  </svg>
  <svg class="theme-icon-moon w-4 h-4 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
  </svg>
  <span class="theme-label"></span>
</button>

<script is:inline>
  function initAllThemeToggles() {
    var theme = localStorage.getItem('theme') || 'dark';

    // Apply theme to HTML
    document.documentElement.classList.remove('dark', 'light');
    document.documentElement.classList.add(theme);

    // Update ALL toggle instances
    var toggles = document.querySelectorAll('.theme-toggle');
    toggles.forEach(function(toggle) {
      var sun = toggle.querySelector('.theme-icon-sun');
      var moon = toggle.querySelector('.theme-icon-moon');
      var label = toggle.querySelector('.theme-label');

      if (!sun || !moon || !label) return;

      if (theme === 'dark') {
        sun.classList.remove('hidden');
        moon.classList.add('hidden');
        label.textContent = 'Light';
        toggle.className = 'theme-toggle flex items-center gap-2 px-3 py-1.5 rounded-lg text-xs font-mono transition-all duration-200 border t-muted';
        toggle.style.borderColor = 'var(--theme-border)';
      } else {
        sun.classList.add('hidden');
        moon.classList.remove('hidden');
        label.textContent = 'Dark';
        toggle.className = 'theme-toggle flex items-center gap-2 px-3 py-1.5 rounded-lg text-xs font-mono transition-all duration-200 border t-muted';
        toggle.style.borderColor = 'var(--theme-border)';
      }

      // Remove old listener via clone
      var newToggle = toggle.cloneNode(true);
      toggle.parentNode.replaceChild(newToggle, toggle);

      newToggle.addEventListener('click', function() {
        var current = localStorage.getItem('theme') || 'dark';
        var next = current === 'dark' ? 'light' : 'dark';
        localStorage.setItem('theme', next);
        initAllThemeToggles();
      });
    });
  }

  // Prevent flash
  (function() {
    var t = localStorage.getItem('theme') || 'dark';
    document.documentElement.classList.remove('dark', 'light');
    document.documentElement.classList.add(t);
  })();

  initAllThemeToggles();
  document.addEventListener('astro:after-swap', initAllThemeToggles);
  document.addEventListener('astro:page-load', initAllThemeToggles);
</script>
